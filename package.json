{
  "name": "commitai",
  "version": "0.1.0",
  "description": "CLI tool to generate commit messages and PR descriptions using AI",
  "main": "dist/index.js",
  "bin": {
    "commitai": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format cjs --clean",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "inquirer": "^8.2.6",
    "openai": "^4.83.0",
    "ora": "^5.4.1",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
