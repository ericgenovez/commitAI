{
  "name": "@ericgenovez/commitai",
  "version": "1.0.2",
  "description": "Professional CLI tool to generate conventional commits and PR descriptions using AI",
  "author": "Eric Genovez",
  "license": "MIT",
  "preferGlobal": true,
  "homepage": "https://github.com/ericgenovez/commitAI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericgenovez/commitAI.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "commitai": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format cjs --minify --clean --dts-resolve",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "axios": "^1.7.9",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "inquirer": "^8.2.6",
    "openai": "^4.83.0",
    "ora": "^5.4.1",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
